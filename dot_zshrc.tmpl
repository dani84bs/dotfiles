export ZSH="${HOME}/.oh-my-zsh"
ZSH_THEME="fishy"
plugins=(direnv z sudo)
VI_MODE_RESET_PROMPT_ON_MODE_CHANGE=true
VI_MODE_SET_CURSOR=true

source $ZSH/oh-my-zsh.sh

__conda_setup="$('${HOME}/miniconda3/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "${HOME}/miniconda3/etc/profile.d/conda.sh" ]; then
        . "${HOME}/miniconda3/etc/profile.d/conda.sh"
    else
        export PATH="${HOME}/miniconda3/bin:$PATH"
    fi
fi
unset __conda_setup

export PATH=$PATH:~/.emacs.d/bin:~/.poetry/bin:~/miniconda3/bin/
show_conda_env() {
  if [[ -n "$CONDA_DEFAULT_ENV" && -n "$DIRENV_DIR" ]]; then
    echo "($(basename $CONDA_DEFAULT_ENV))"
  fi
}

dea() {
  if (( $# == 0 ))
      then echo usage: dea name ...;
      return
  fi
      echo layout anaconda $1 > ./.envrc
      direnv allow
}
export show_conda_env
PS1='$(show_conda_env)'$PS1


export PATH=$PATH:${HOME}/.flutter/flutter/bin

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

{{ if eq .chezmoi.os "darwin" }}
export ANDROID_SDK=${HOME}/Library/Android/sdk
export ANDROID_HOME=${HOME}/Library/Android/sdk
export PATH=$PATH:${ANDROID_HOME}/emulator
export PATH=$PATH:${ANDROID_HOME}/platform-tools
export PATH=$PATH:${ANDROID_HOME}/emulators
export PATH=$PATH:${ANDROID_HOME}/tools
export PATH=$PATH:${ANDROID_HOME}/tools/bin
{{ end }}
